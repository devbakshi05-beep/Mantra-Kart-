            referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: "textarea",
            plugins: "lists",
            menubar: "file edit format"
        })
        function ValData()
        {
            if(document.getElementById('imageId').value == "")
            {
                swal('Error','Please Select Image !!!','error');
                return false;
            }
        }
    </script>
}

